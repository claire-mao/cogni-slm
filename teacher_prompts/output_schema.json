{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "TeacherPromptOutput",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "teacher_reasoning",
    "feedback",
    "rubric_analysis",
    "final_score"
  ],
  "properties": {
    "teacher_reasoning": {
      "type": "string",
      "minLength": 1
    },
    "feedback": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "strengths",
        "weaknesses",
        "next_step"
      ],
      "properties": {
        "strengths": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "weaknesses": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "next_step": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "rubric_analysis": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "claim",
        "evidence",
        "commentary",
        "organization_style"
      ],
      "properties": {
        "claim": {
          "type": "string",
          "minLength": 1
        },
        "evidence": {
          "type": "string",
          "minLength": 1
        },
        "commentary": {
          "type": "string",
          "minLength": 1
        },
        "organization_style": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "final_score": {
      "type": "number"
    }
  }
}
