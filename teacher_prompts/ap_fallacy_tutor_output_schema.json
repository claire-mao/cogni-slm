{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "teacher_prompts/ap_fallacy_tutor_output_schema.json",
  "title": "AP Fallacy Tutor Teacher Output",
  "type": "object",
  "required": [
    "score",
    "confidence",
    "reasoning",
    "rubric_analysis",
    "feedback",
    "behavior_output"
  ],
  "properties": {
    "score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "reasoning": {
      "type": "string",
      "minLength": 1
    },
    "rubric_analysis": {
      "type": "string",
      "minLength": 1
    },
    "feedback": {
      "type": "string",
      "minLength": 1
    },
    "behavior_output": {
      "type": "object",
      "required": [
        "argument_summary",
        "assumptions",
        "primary_fallacy",
        "why_this_applies",
        "cross_domain_analogy",
        "transfer_check",
        "reflective_question"
      ],
      "properties": {
        "argument_summary": {
          "type": "string",
          "minLength": 1
        },
        "assumptions": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "minLength": 1
          }
        },
        "primary_fallacy": {
          "type": "string",
          "minLength": 1
        },
        "why_this_applies": {
          "type": "string",
          "minLength": 1
        },
        "cross_domain_analogy": {
          "type": "object",
          "required": [
            "analogy",
            "mapping"
          ],
          "properties": {
            "analogy": {
              "type": "string",
              "minLength": 1
            },
            "mapping": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": true
        },
        "transfer_check": {
          "type": "object",
          "required": [
            "example",
            "question",
            "answer_revealed"
          ],
          "properties": {
            "example": {
              "type": "string",
              "minLength": 1
            },
            "question": {
              "type": "string",
              "minLength": 1
            },
            "answer_revealed": {
              "type": "boolean",
              "const": false
            }
          },
          "additionalProperties": true
        },
        "reflective_question": {
          "type": "string",
          "pattern": "\\?$",
          "minLength": 2
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
