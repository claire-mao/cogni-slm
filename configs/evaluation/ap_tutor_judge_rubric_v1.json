      "description": "Measures adherence to the 7-step AP tutoring contract.",
      "criteria": [
        "argument summary present",
        "assumptions identified",
        "one primary fallacy or explicit none",
        "fallacy explanation provided",
        "cross-domain analogy with mapping",
        "transfer example without answer",
        "exactly one reflective question"
      ],
      "min_score": 0.0,
      "max_score": 1.0
    },
    {
