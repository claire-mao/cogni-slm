{
  "version": "teacher_pilot_live_v1",
  "created_at": "2026-07-09",
  "objective": "Execute live pilot teacher validation on 20 gold examples.",
  "inputs": {
    "dataset_path": "datasets/gold/pilot20_v1.jsonl",
    "task_suite_path": "configs/teacher/teacher_task_suite_v1.json",
    "metrics_reference_path": "configs/teacher/teacher_metrics_v1.json",
    "models_costs_path": "configs/teacher/teacher_models_costs_v1.json",
    "prompt_template": "teacher_prompts/production_teacher.txt",
    "prompt_version": "production_teacher_v1",
    "schema_path": "teacher_prompts/output_schema.json"
  },
  "models": [
    {
      "model_id": "gpt-5",
      "display_name": "GPT-5",
      "provider": "openai"
    },
    {
      "model_id": "claude_opus_4x",
      "display_name": "Claude Opus 4",
      "provider": "anthropic"
    },
    {
      "model_id": "deepseek_r1",
      "display_name": "DeepSeek R1",
      "provider": "deepseek"
    }
  ],
  "tasks": [
    "essay_scoring",
    "rubric_adherence",
    "educational_feedback",
    "logical_reasoning",
    "argument_quality",
    "logical_fallacy_identification"
  ],
  "run_parameters": {
    "temperatures": [
      0.0
    ],
    "seeds": [
      42
    ],
    "max_output_tokens": 1400,
    "timeout_seconds": 120,
    "strict_json_required": true,
    "dry_run": false
  },
  "metrics": {
    "primary": [
      "quadratic_weighted_kappa",
      "mae",
      "rubric_adherence",
      "feedback_quality",
      "json_validity",
      "hallucination_rate",
      "logical_reasoning",
      "fallacy_detection",
      "agreement",
      "cost",
      "latency"
    ]
  },
  "outputs": {
    "run_id": "teacher-pilot20-live-v1",
    "run_root": "outputs/teacher_runs/teacher-pilot20-live-v1",
    "responses_path": "outputs/teacher_runs/teacher-pilot20-live-v1/responses.jsonl",
    "summary_path": "outputs/teacher_runs/teacher-pilot20-live-v1/summary.json",
    "report_path": "docs/reports/teacher_pilot_live.md"
  }
}
