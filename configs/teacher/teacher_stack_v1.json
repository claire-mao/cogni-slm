{
  "version": "teacher_stack_v1",
  "stack_name": "production_teacher_stack_v1",
  "created_at": "2026-07-09",
  "json_schema_version": "production_teacher_output_schema_v1",
  "json_schema_path": "teacher_prompts/output_schema.json",
  "prompt_version": "production_teacher_v1",
  "prompt_path": "teacher_prompts/production_teacher.txt",
  "intended_task_list": [
    "essay_scoring",
    "rubric_adherence",
    "educational_feedback",
    "logical_reasoning",
    "argument_quality",
    "logical_fallacy_identification",
    "revision_suggestions"
  ],
  "confidence_thresholds": {
    "primary_accept_min": 0.75,
    "verifier_required_below": 0.75,
    "reasoning_checker_required_below": 0.7,
    "auto_reject_below": 0.45,
    "disagreement_escalation_delta": 0.2
  },
  "models": {
    "primary_teacher": {
      "role": "primary_teacher",
      "model_name": "GPT-5",
      "model_id": "gpt-5",
      "provider": "openai",
      "api_endpoint": "${OPENAI_BASE_URL}/v1/responses",
      "model_version": "gpt-5-stable",
      "prompt_version": "production_teacher_v1",
      "temperature": 0.0,
      "max_tokens": 1800,
      "reasoning_settings": {
        "reasoning_effort": "high",
        "evidence_anchored_reasoning": true,
        "strict_json_only": true
      },
      "retry_policy": {
        "max_attempts": 3,
        "initial_backoff_ms": 1000,
        "max_backoff_ms": 8000,
        "retry_on": [
          "timeout",
          "rate_limit",
          "server_error",
          "invalid_json"
        ]
      },
      "timeout_seconds": 90,
      "json_schema_version": "production_teacher_output_schema_v1",
      "intended_task_list": [
        "essay_scoring",
        "rubric_adherence",
        "educational_feedback",
        "logical_reasoning",
        "argument_quality",
        "logical_fallacy_identification",
        "revision_suggestions"
      ],
      "confidence_thresholds": {
        "target_min_confidence": 0.75,
        "manual_review_below": 0.6
      }
    },
    "verifier": {
      "role": "verifier",
      "model_name": "Claude Opus 4",
      "model_id": "claude-opus-4",
      "provider": "anthropic",
      "api_endpoint": "${ANTHROPIC_BASE_URL}/v1/messages",
      "model_version": "claude-opus-4-stable",
      "prompt_version": "production_teacher_v1",
      "temperature": 0.0,
      "max_tokens": 1400,
      "reasoning_settings": {
        "reasoning_effort": "high",
        "verification_mode": "strict_cross_check",
        "strict_json_only": true
      },
      "retry_policy": {
        "max_attempts": 3,
        "initial_backoff_ms": 1000,
        "max_backoff_ms": 8000,
        "retry_on": [
          "timeout",
          "rate_limit",
          "server_error",
          "invalid_json"
        ]
      },
      "timeout_seconds": 120,
      "json_schema_version": "production_teacher_output_schema_v1",
      "intended_task_list": [
        "rubric_adherence",
        "logical_reasoning",
        "logical_fallacy_identification",
        "educational_feedback"
      ],
      "confidence_thresholds": {
        "verification_pass_min": 0.7,
        "escalate_to_human_below": 0.55
      }
    },
    "reasoning_checker": {
      "role": "reasoning_checker",
      "model_name": "DeepSeek R1",
      "model_id": "deepseek-reasoner",
      "provider": "deepseek",
      "api_endpoint": "${DEEPSEEK_BASE_URL}/v1/chat/completions",
      "model_version": "deepseek-r1-stable",
      "prompt_version": "production_teacher_v1",
      "temperature": 0.0,
      "max_tokens": 1000,
      "reasoning_settings": {
        "reasoning_effort": "high",
        "consistency_check": true,
        "strict_json_only": true
      },
      "retry_policy": {
        "max_attempts": 2,
        "initial_backoff_ms": 800,
        "max_backoff_ms": 5000,
        "retry_on": [
          "timeout",
          "rate_limit",
          "server_error",
          "invalid_json"
        ]
      },
      "timeout_seconds": 90,
      "json_schema_version": "production_teacher_output_schema_v1",
      "intended_task_list": [
        "logical_reasoning",
        "argument_quality",
        "logical_fallacy_identification"
      ],
      "confidence_thresholds": {
        "checker_pass_min": 0.65,
        "escalate_to_verifier_below": 0.55
      }
    }
  },
  "escalation_policy": {
    "escalate_on_invalid_json": true,
    "escalate_on_schema_failure": true,
    "escalate_on_score_disagreement_ge": 2,
    "escalate_on_fallacy_label_disagreement": true,
    "escalate_on_low_confidence_any_role_below": 0.55,
    "human_review_required_if": [
      "primary_vs_verifier_disagreement",
      "verifier_vs_checker_disagreement",
      "repeated_retry_exhaustion"
    ]
  },
  "reproducibility": {
    "deterministic_temperature": true,
    "temperature_default": 0.0,
    "fixed_seed": 42,
    "prompt_hash_required": true,
    "schema_hash_required": true,
    "log_raw_outputs": true,
    "log_token_usage": true,
    "log_latency_ms": true
  }
}
