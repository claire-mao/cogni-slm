{
  "version": "teacher_validation_v1",
  "created_at": "2026-07-09",
  "objective": "Select the highest-quality teacher model or ensemble for educational assessment supervision before dataset labeling.",
  "inputs": {
    "reports": [
      "docs/reports/teacher_models_overview.md",
      "docs/reports/teacher_models_education.md",
      "docs/reports/teacher_models_deployment.md",
      "docs/reports/teacher_model_selection.md"
    ]
  },
  "configs": {
    "task_suite": "configs/teacher/teacher_task_suite_v1.json",
    "gold_set": "configs/teacher/teacher_gold_set_v1.json",
    "metrics": "configs/teacher/teacher_metrics_v1.json",
    "models_costs": "configs/teacher/teacher_models_costs_v1.json",
    "ensembles": "configs/teacher/teacher_ensembles_v1.json",
    "round_schedule": "configs/teacher/teacher_rounds_v1.json"
  },
  "guardrails": {
    "allow_dataset_modification": false,
    "allow_label_generation": false,
    "allow_model_inference": false
