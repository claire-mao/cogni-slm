    "models_costs": "configs/teacher/teacher_models_costs_v1.json",
    "ensembles": "configs/teacher/teacher_ensembles_v1.json",
    "round_schedule": "configs/teacher/teacher_rounds_pilot20_v2.json"
  },
  "inputs": {
    "dataset_path": "datasets/gold/pilot20_v1.jsonl",
