{
  "version": "providers_v1",
  "description": "TrueFoundry gateway requirements for teacher execution.",
  "env_file_default": ".env",
  "aliases": {
    "gemini": "google",
    "openrouter_compatible": "openrouter",
    "truefoundry": "openai"
  },
  "providers": {
    "openai": {
      "required_env_all": [
        "PRIMARY_TEACHER_MODEL",
        "VERIFIER_MODEL",
        "SECONDARY_MODEL"
      ],
      "required_env_any": [
        [
          "TFY_API_KEY",
          "TRUEFOUNDRY_API_KEY"
        ],
        [
          "TFY_BASE_URL",
          "TRUEFOUNDRY_BASE_URL"
        ]
      ],
      "optional_env": []
    },
    "anthropic": {
      "required_env_all": [
        "PRIMARY_TEACHER_MODEL",
        "VERIFIER_MODEL",
        "SECONDARY_MODEL"
      ],
      "required_env_any": [
        [
          "TFY_API_KEY",
          "TRUEFOUNDRY_API_KEY"
        ],
        [
          "TFY_BASE_URL",
          "TRUEFOUNDRY_BASE_URL"
        ]
      ],
      "optional_env": []
    },
    "google": {
      "required_env_all": [
        "PRIMARY_TEACHER_MODEL",
        "VERIFIER_MODEL",
        "SECONDARY_MODEL"
      ],
      "required_env_any": [
        [
          "TFY_API_KEY",
          "TRUEFOUNDRY_API_KEY"
        ],
        [
          "TFY_BASE_URL",
          "TRUEFOUNDRY_BASE_URL"
        ]
      ],
      "optional_env": []
    },
    "deepseek": {
      "required_env_all": [
        "PRIMARY_TEACHER_MODEL",
        "VERIFIER_MODEL",
        "SECONDARY_MODEL"
      ],
      "required_env_any": [
        [
          "TFY_API_KEY",
          "TRUEFOUNDRY_API_KEY"
        ],
        [
          "TFY_BASE_URL",
          "TRUEFOUNDRY_BASE_URL"
        ]
      ],
      "optional_env": []
    },
    "openrouter": {
      "required_env_all": [
        "PRIMARY_TEACHER_MODEL",
        "VERIFIER_MODEL",
        "SECONDARY_MODEL"
      ],
      "required_env_any": [
        [
          "TFY_API_KEY",
          "TRUEFOUNDRY_API_KEY"
        ],
        [
          "TFY_BASE_URL",
          "TRUEFOUNDRY_BASE_URL"
        ]
      ],
      "optional_env": []
    }
  }
}
