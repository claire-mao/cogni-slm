{
  "model_id": "Qwen/Qwen3-1.7B-Instruct",
  "qlora": {
    "max_seq_length": 2048,
    "load_in_4bit": true,
    "lora_r": 16,
    "lora_alpha": 16,
    "lora_dropout": 0.0,
    "bias": "none",
    "use_gradient_checkpointing": "unsloth",
    "random_state": 42,
    "target_modules": [
      "q_proj",
      "k_proj",
      "v_proj",
      "o_proj",
      "gate_proj",
      "up_proj",
      "down_proj"
    ]
  },
  "dataset": {
    "dataset_path": "datasets/training",
    "train_split": "train",
    "eval_split": "validation",
    "text_field": "text",
    "prompt_field": "prompt",
    "essay_field": "essay",
    "score_field": "score",
    "max_train_samples": 0,
    "max_eval_samples": 0
  },
  "trainer": {
    "output_dir": "models/unsloth_qlora",
    "logging_dir": "outputs/training_logs",
    "num_train_epochs": 1.0,
    "learning_rate": 0.0002,
    "weight_decay": 0.0,
    "warmup_ratio": 0.03,
    "lr_scheduler_type": "cosine",
    "seed": 42,
    "per_device_train_batch_size": 2,
    "per_device_eval_batch_size": 2,
    "gradient_accumulation_steps": 8,
    "eval_steps": 50,
    "save_steps": 50,
    "logging_steps": 10,
    "save_total_limit": 3,
    "evaluation_strategy": "steps",
    "save_strategy": "steps",
    "logging_strategy": "steps",
    "report_to": []
  },
  "checkpoint_dir": "models/unsloth_qlora/checkpoints",
  "metadata_path": "models/unsloth_qlora/run_metadata.json",
  "eval_log_path": "outputs/training_logs/eval_metrics.jsonl"
}
