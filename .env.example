# Cogni runtime environment
COGNI_ENV=development
PYTHONPATH=src

# Model defaults
COGNI_BASE_MODEL=Qwen/Qwen3-1.7B
COGNI_TUNED_MODEL=

# Data and artifact locations
COGNI_DATA_ROOT=datasets
COGNI_OUTPUT_ROOT=outputs

# Optional external services
# Provider routing mode:
# - truefoundry (default): uses TFY_* / TRUEFOUNDRY_* vars below
# - direct: uses TEACHER_API_KEY + TEACHER_BASE_URL (OpenAI-compatible endpoint)
TEACHER_PROVIDER_MODE=truefoundry

# Direct OpenAI-compatible routing (used when TEACHER_PROVIDER_MODE=direct)
TEACHER_API_KEY=
TEACHER_BASE_URL=

# Preferred TrueFoundry gateway variables
TFY_API_KEY=
TFY_BASE_URL=https://tfy.promptlens.trilogy.com/v1

# Backward-compatible aliases (optional if TFY_* is set)
TRUEFOUNDRY_API_KEY=
TRUEFOUNDRY_BASE_URL=
PRIMARY_TEACHER_MODEL=openai-group/gpt-5
VERIFIER_MODEL=claude-group/claude-opus-4-8
SECONDARY_MODEL=gemini-group/gemini-3.1-pro
HUGGINGFACE_HUB_TOKEN=
WANDB_API_KEY=
